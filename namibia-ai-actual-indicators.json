import json, math, openpyxl, shapefile

regions = ["//Kharas","Erongo","Hardap","Kavango East","Kavango West","Khomas","Kunene","Ohangwena","Omaheke","Omusati","Oshana","Oshikoto","Otjozondjupa","Zambezi"]

def clean_name(name):
    if name in ("Kharas", "!Karas", "Karas"):
        return "//Kharas"
    return name

wb = openpyxl.load_workbook('NSA_2023_Census_Main_Tables.xlsx', data_only=True, read_only=True)

def rows(sheet):
    return wb[sheet].iter_rows(values_only=True)

internet = {}
for row in rows('Table 5.2'):
    name = clean_name(row[0]) if row and row[0] else None
    if name in regions:
        internet[name] = float(row[2])

smartphone = {}
for row in rows('Table 5.1'):
    name = clean_name(row[0]) if row and row[0] else None
    if name in regions:
        smartphone[name] = float(row[5])

youth_lit = {}
for row in rows('Fig 5.4 Youth Literacy rate'):
    name = clean_name(row[0]) if row and row[0] else None
    if name in regions:
        youth_lit[name] = float(row[9])

population = {}
youth_share = {}
for row in rows('Table 2.3'):
    name = clean_name(row[1]) if len(row) > 1 and row[1] else None
    if name in regions and isinstance(row[2], (int, float)):
        population[name] = int(row[2])
        youth_share[name] = float(row[4]) + float(row[5])
    name2 = clean_name(row[13]) if len(row) > 13 and row[13] else None
    if name2 in regions and isinstance(row[19], (int, float)):
        population[name2] = int(row[19])
        youth_share[name2] = float(row[21]) + float(row[22])

urban = {}
for row in rows('Table 4.4'):
    name = clean_name(row[0]) if row and row[0] else None
    if name in regions and isinstance(row[8], (int, float)):
        urban[name] = float(row[8])

reader = shapefile.Reader('regions14/Regions.shp')
windhoek_lon, windhoek_lat = 17.0832, -22.5597

def centroid(shape):
    pts = shape.points
    return sum(p[0] for p in pts) / len(pts), sum(p[1] for p in pts) / len(pts)

def haversine(lon1, lat1, lon2, lat2):
    r = 6371.0
    phi1, phi2 = math.radians(lat1), math.radians(lat2)
    dphi = math.radians(lat2 - lat1)
    dlambda = math.radians(lon2 - lon1)
    a = math.sin(dphi/2)**2 + math.cos(phi1)*math.cos(phi2)*math.sin(dlambda/2)**2
    return 2*r*math.atan2(math.sqrt(a), math.sqrt(1-a))

distance_km = {}
for sr in reader.shapeRecords():
    name = clean_name(sr.record.as_dict()['NAME_'])
    cx, cy = centroid(sr.shape)
    distance_km[name] = haversine(windhoek_lon, windhoek_lat, cx, cy)

missing = {k: [r for r in regions if r not in d] for k,d in [('internet',internet),('smartphone',smartphone),('youth_lit',youth_lit),('population',population),('urban',urban),('distance',distance_km)]}
print('missing', missing)

max_pop = max(population.values())
max_dist = max(distance_km.values())
weights = {'connectivityGapIndex': 0.30, 'skillsGapIndex': 0.25, 'distanceIndex': 0.20, 'servicePressureIndex': 0.15, 'ruralShareIndex': 0.10}
actual = {}
for name in regions:
    raw = {
        'internetBrowsingPct': internet[name],
        'smartphoneOwnershipPct': smartphone[name],
        'youthLiteracyPct': youth_lit[name],
        'population2023': population[name],
        'youthSharePct': youth_share[name],
        'urbanPopulationPct': urban[name],
        'ruralPopulationPct': 100 - urban[name],
        'distanceFromWindhoekKm': distance_km[name],
    }
    components = {
        'connectivityGapIndex': 100 - raw['internetBrowsingPct'],
        'skillsGapIndex': 100 - raw['youthLiteracyPct'],
        'distanceIndex': 100 * raw['distanceFromWindhoekKm'] / max_dist,
        'servicePressureIndex': 100 * raw['population2023'] / max_pop,
        'ruralShareIndex': raw['ruralPopulationPct'],
    }
    score = round(sum(components[k] * weights[k] for k in weights))
    actual[name] = {'raw': raw, 'components': components, 'score': score}

with open('namibia-ai-actual-indicators.json', 'w', encoding='utf-8') as f:
    json.dump(actual, f, ensure_ascii=False, indent=2)

for name in sorted(actual, key=lambda n: actual[n]['score'], reverse=True):
    print(name, actual[name]['score'], {k: round(v,1) if isinstance(v,float) else v for k,v in actual[name]['raw'].items()})
